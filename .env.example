# Public site URL (used for canonical/sitemap/OG)
NEXT_PUBLIC_SITE_URL="https://bestscreentester.com"

# Contact address used by the feedback/contact page (mailto link)
NEXT_PUBLIC_CONTACT_EMAIL="geeslyhelp@gmail.com"

# Google Analytics 4 Measurement ID. Defaults to the site's ID in code; only set
# this to override (e.g. a separate staging property).
NEXT_PUBLIC_GA_ID=""

# Google Search Console verification token (the value from the "HTML tag" method).
# Optional — you can also verify via the Google Analytics already on the site.
NEXT_PUBLIC_GSC_VERIFICATION=""
